#include<iostream>
using namespace std;
int isValid(int arr[], int mid, int n,int m)
{
    int totalWood = 0;

    for(int i = 0; i < n; i++)
    {
        if(arr[i] > mid)
        {
            int currentWood = arr[i]-mid;
            totalWood += currentWood;
        }
    }
    if(totalWood >= m)
    {
        return true;
    }
    else{
        return false;
    }
}

int maxSawHeight(int arr[], int m)
{
    int n = 4;
    int s = 0;

    int maxi = 0;

    for(int i =0; i < n; i++)
    {
        if(arr[i] > maxi)
        {
            maxi = arr[i];
        }
    }
    int e = maxi;
    int ans = 0;

    while( s<= e)
    {
        int mid =  s + (e-s)/2;
        if(isValid(arr,mid,n,m))
        {
            ans = mid; 
            s = mid + 1;
        }
        else{
            e = mid - 1;
        }
    }
    return ans;

}

int main()
{
    int arr[4] = {20,15,10,17};
    int m = 7;
    int ans = maxSawHeight(arr,m);
    cout << ans;
}

#include<iostream>
using namespace std;

int FirstOcc(int *arr, int s, int e, int k)
{
    int mid = s + (e - s) / 2;
    if(s > e)
    return -1;

    if(arr[mid] == k)
    {
        int first = FirstOcc(arr, s, mid - 1, k);
        if(first == -1)
        return mid;
        else{
            return first;
        }
    }
    if(arr[mid] > k)
    {
        return FirstOcc(arr, s, mid - 1, k);
    }
    else {
        return FirstOcc(arr, mid + 1, e, k);
    }
}

int LastOcc(int *arr, int s, int e, int k)
{                                                                                                                                
    int mid = s + (e - s) / 2;
    if(s > e)
    return -1;

    if(arr[mid] == k)
    {
        int last = LastOcc(arr, mid + 1, e, k);
        if(last == -1)
        return mid;
        else{
            return last;                                                                                                     
        }
    }
    if(arr[mid] > k)
    {
        return LastOcc(arr, s, mid - 1, k);
    }
    else {
        return LastOcc(arr, mid + 1, e, k);
    }
}
int main()
{
    int arr[4] = {1, 2, 2, 2};
    int f = FirstOcc(arr, 0, 3, 2);
    int l = LastOcc(arr, 0, 3, 2);

    cout << f << " " << l;

}



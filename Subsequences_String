#include <bits/stdc++.h>

void solve(int index, string str, vector<string> &ans, string output)
{
    if(index >= str.length())
    {
        if(output.length() > 0)
        {
            ans.push_back(output);
            
        }
        return;
    }

        solve(index+1, str, ans, output);

        output.push_back(str[index]);
        solve(index+1, str, ans, output);
}
vector<string> subsequences(string str){
	
	vector<string>ans;
	string output = "";
    solve(0, str, ans, output);
    return ans;
	
}
